# Comma-separated Personal Access Tokens (classic or fine-grained with read access to users/search)
PORT=3001
GITHUB_TOKENS=ghp_xxx,ghp_yyy,ghp_zzz

# SQLite file for saved people + notes (default: backend/data/findman.sqlite)
# SQLITE_PATH=D:/path/to/findman.sqlite

# On startup: search GitHub, enrich profiles, upsert into SQLite (same as saving from the UI).
# Each successful run schedules the next automatically (default spacing 90s). Search API page rotates
# (page 1, 2, … within GitHub’s 1000-result cap) and is stored in SQLite (`app_settings`) so restarts resume
# the same page; if the saved page is past max for current total_count, the backend resets to page 1.
# AUTO_SEARCH_ENABLED=false
# AUTO_SEARCH_QUERY=location:"United States" type:user
# AUTO_SEARCH_PER_PAGE=15
# AUTO_SEARCH_INTERVAL_MS=90000

# When total GitHub Search results for a query exceed GitHub's 1000-result cap,
# the auto-search splits by `created:` date ranges and processes them oldest-first.
# These control the initial split range used for the first probe query.
# AUTO_SEARCH_CREATED_FROM=2008-01-01
# AUTO_SEARCH_CREATED_TO=2026-03-25

# Optional: restrict which origins can call the API (comma-separated). Empty = reflect request origin (dev-friendly).
# CORS_ORIGINS=http://localhost:5173
